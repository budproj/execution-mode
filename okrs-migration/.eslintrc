{
  "extends": [
    "@budproj/eslint-config-base-ts",
    "@budproj/eslint-config-prettier-ts",
    "@budproj/eslint-config-intl",
    "@budproj/eslint-config-react"
  ],
  "rules": {
    "quotes": [
      "error",
      "single"
    ],
    "import/extensions": [
      "error",
      "ignorePackages",
      {
        "js": "always",
        "ts": "always"
      }
    ]
  },
  "settings": {
    "import/resolver": {
      "node": {
        "paths": [
          "./",
          "src"
        ]
      },
      "typescript": {
        "project": "./tsconfig.json"
      }
    }
  }
}
